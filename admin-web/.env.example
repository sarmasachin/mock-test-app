# Real hostname only — not a placeholder. "apna-domain" or fake hosts cause ERR_NAME_NOT_RESOLVED in the browser.
# Local:  http://127.0.0.1:3000/v1
# Live:   https://YOUR-ACTUAL-DOMAIN.com/v1   (same origin as admin panel or wherever API is exposed)
VITE_API_BASE_URL=http://127.0.0.1:3000/v1

# Optional: enables “Continue with Google” on admin login (must match server GOOGLE_WEB_CLIENT_ID).
# Google Cloud Console → OAuth client → Authorized JavaScript origins: e.g. http://127.0.0.1:5173
# VITE_GOOGLE_WEB_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
