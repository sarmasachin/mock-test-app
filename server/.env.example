PORT=3000
DATABASE_URL=postgresql://mocktestapp_rw:MockDb123@127.0.0.1:5432/mocktestapp
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Public HTTPS origin of this API (no trailing slash). Required for signed "Unsubscribe" links in non-OTP emails.
# Production: https://admin-admin.govmocktest.com (see deploy/DEPLOY.txt)
# PUBLIC_API_BASE_URL=https://admin-admin.govmocktest.com
# EMAIL_PUBLIC_UNSUBSCRIBE_BASE_URL=https://admin-admin.govmocktest.com

# Optional production hardening: comma-separated exact Origin values (scheme+host+port).
# Example (Vite admin dev): http://127.0.0.1:5173,http://localhost:5173
# Live admin panel: https://admin-admin.govmocktest.com/admin/
# CORS_ALLOWED_ORIGINS=https://admin-admin.govmocktest.com,http://127.0.0.1:5173,http://localhost:5173
# If unset, CORS allows any origin (convenient for local dev + mobile apps without Origin).
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Subcategory pool regeneration (dynamic tests): ~REGENERATE_NEW_RATIO from last REGENERATE_NEW_WINDOW_DAYS days, rest older.
# REGENERATE_NEW_RATIO=0.8
# REGENERATE_NEW_WINDOW_DAYS=7

# DB pool tuning (Phase-2)
# DB_POOL_MAX=25
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECT_TIMEOUT_MS=10000

ACCESS_TOKEN_TTL_SECONDS=86400
REFRESH_TOKEN_TTL_DAYS=14

# Admin audit log retention (PostgreSQL admin_audit_logs). Newest N rows kept; older deleted after each new entry.
# ADMIN_AUDIT_LOG_MAX_ROWS=100

# Password login security mail: skip "new device" alerts while account is younger than this many hours (default 48).
# NEW_ACCOUNT_LOGIN_ALERT_GRACE_HOURS=48

# Admin panel web login (password → email OTP). Same SMTP pool as other OTP mail.
#
# LOCAL ONLY: skip email OTP after correct admin password (no SMTP mail for that step).
# Never set to true on a public/production host (omit this line or use false). Admin UI handles devPasswordBypass.
# ADMIN_DEV_PASSWORD_LOGIN=true
# ADMIN_LOGIN_OTP_MINUTES=15
# MAIL_SUBJECT_ADMIN_LOGIN=Your admin panel login code
# Optional subject override for admin / super-admin invitation email (defaults are set in code).
# MAIL_SUBJECT_ADMIN_ROLE=You are invited as an Admin on MockTestApp
# Full URL of the admin web app (used in the "Open admin panel" button in admin-role emails).
# MAIL_ADMIN_PANEL_URL=https://admin-admin.govmocktest.com/admin
# OTP_ADMIN_LOGIN_REQUEST_MAX_PER_IP=25
# OTP_ADMIN_LOGIN_REQUEST_MAX_PER_USER=8
# OTP_ADMIN_LOGIN_VERIFY_MAX_PER_IP=60

# Google Sign-In (Android ID token verification) — separate from SMTP mail above.
# API reads only the GOOGLE_SIGN_IN_* vars below (not GOOGLE_WEB_CLIENT_ID; that name is for Android build.gradle).
# Use the Web client ID (OAuth client type 3) from Firebase / Google Cloud, same as Android requestIdToken(...).
GOOGLE_SIGN_IN_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# If verify still fails, add Android OAuth client id too (type 1 from google-services.json) — token "aud" must match one of these.
GOOGLE_SIGN_IN_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Password reset (Gmail): enable 2-Step Verification, then create an App Password
# https://myaccount.google.com/apppasswords — use that value for SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youraccount@gmail.com
SMTP_PASS=your-16-char-app-password
# For Gmail: the address inside MAIL_FROM must be the SAME mailbox as SMTP_USER (or Google often rejects / 535).
MAIL_FROM="MockTestApp <youraccount@gmail.com>"
# SMTP timeout tuning (prevents long hangs on hosted environments)
# SMTP_CONNECTION_TIMEOUT_MS=10000
# SMTP_GREETING_TIMEOUT_MS=10000
# SMTP_SOCKET_TIMEOUT_MS=15000
# Optional:
# MAIL_SUBJECT_RESET=Your reset code
# MAIL_SUBJECT_EMAIL_VERIFY=Your verification code
# MAIL_BRAND_NAME=MockTestApp
# MAIL_LOGO_URL=https://your-domain.com/logo.png
# MAIL_SUPPORT_EMAIL=support@your-domain.com
# MAIL_APP_URL=https://play.google.com/store/apps/details?id=com.freemocktest.app
# MAIL_COMPLETE_PROFILE_DEEP_LINK=mocktestapp://complete-profile
# PASSWORD_RESET_OTP_MINUTES=15

# OTP send rate limits (single API instance; in-memory). Reduces Gmail 454 / abuse.
# OTP_REQUEST_WINDOW_MS=900000
# OTP_PASSWORD_RESET_MAX_PER_IP=30
# OTP_PASSWORD_RESET_MAX_PER_EMAIL=5
# OTP_EMAIL_VERIFY_MAX_PER_USER=8
# Reuse one SMTP pool for OTP mail (fewer AUTH handshakes to Gmail)
# SMTP_POOL_MAX_MESSAGES=200

# Optional separate mailbox for admin-only OTP (only if your deployment still uses those routes).
# Replace the app password placeholder — a literal "your-admin-reset-app-password" will always fail SMTP auth.
# SMTP_ADMIN_FP_HOST=smtp.gmail.com
# SMTP_ADMIN_FP_PORT=587
# SMTP_ADMIN_FP_SECURE=false
# SMTP_ADMIN_FP_USER=admin-reset-mailbox@gmail.com
# SMTP_ADMIN_FP_PASS=real-16-char-app-password
# MAIL_FROM_ADMIN_FP="MockTest Admin Security <admin-reset-mailbox@gmail.com>"

# FCM Push (admin-controlled notifications)
FCM_PROJECT_ID=your-firebase-project-id
# Keep as single-line JSON string of service account
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-firebase-project-id"}

# Optional: Redis + Bull queue for test_attempt inserts (smooths DB spikes). Same API response; requires Redis running.
# REDIS_URL=redis://127.0.0.1:6379
# ATTEMPT_QUEUE_CONCURRENCY=8
# ATTEMPT_QUEUE_JOB_TIMEOUT_MS=45000

# Graceful shutdown: on SIGTERM/SIGINT — stop new HTTP connections, finish in-flight requests, close Bull + DB pool (ms).
# SHUTDOWN_TIMEOUT_MS=30000

# Attempts submit protection (Phase-3/4)
# Per-user limit in one window.
# ATTEMPT_SUBMIT_WINDOW_MS=10000
# ATTEMPT_SUBMIT_MAX_PER_WINDOW=8
# Global submit cap in one window across users.
# ATTEMPT_SUBMIT_GLOBAL_MAX_PER_WINDOW=500

# Auto-cycle republish gap: minutes to wait after duration_minutes ends before republishing (default 30).
# Unset or invalid → 30 (same as legacy hardcoded behavior). Per-test override in admin Advanced config.
# CYCLE_REPUBLISH_GAP_MINUTES=30

# Log alert when publish schedule items are overdue by at least this many minutes (default 5).
# PUBLISH_SCHEDULE_OVERDUE_ALERT_MINUTES=5
