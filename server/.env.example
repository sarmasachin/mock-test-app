PORT=3000
DATABASE_URL=postgresql://mocktestapp_rw:MockDb123@127.0.0.1:5432/mocktestapp
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Optional production hardening: comma-separated exact Origin values (scheme+host+port).
# Example (Vite admin dev): http://127.0.0.1:5173,http://localhost:5173
# Live admin panel: https://indiaapk.com/admin/  → browser Origin is https://indiaapk.com (no path), e.g.:
# CORS_ALLOWED_ORIGINS=https://indiaapk.com,http://127.0.0.1:5173,http://localhost:5173
# If unset, CORS allows any origin (convenient for local dev + mobile apps without Origin).
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# DB pool tuning (Phase-2)
# DB_POOL_MAX=25
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECT_TIMEOUT_MS=10000

ACCESS_TOKEN_TTL_SECONDS=86400
REFRESH_TOKEN_TTL_DAYS=14

# Google Sign-In (Android ID token verification) — separate from SMTP mail above.
# Use the Web client ID (OAuth client type 3) from Firebase / Google Cloud, same as Android requestIdToken(...).
GOOGLE_SIGN_IN_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# If verify still fails, add Android OAuth client id too (type 1 from google-services.json) — token "aud" must match one of these.
GOOGLE_SIGN_IN_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Password reset (Gmail): enable 2-Step Verification, then create an App Password
# https://myaccount.google.com/apppasswords — use that value for SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youraccount@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM="MockTestApp <youraccount@gmail.com>"
# SMTP timeout tuning (prevents long hangs on hosted environments)
# SMTP_CONNECTION_TIMEOUT_MS=10000
# SMTP_GREETING_TIMEOUT_MS=10000
# SMTP_SOCKET_TIMEOUT_MS=15000
# Optional:
# MAIL_SUBJECT_RESET=Your reset code
# MAIL_SUBJECT_EMAIL_VERIFY=Your verification code
# MAIL_BRAND_NAME=MockTestApp
# MAIL_LOGO_URL=https://your-domain.com/logo.png
# MAIL_SUPPORT_EMAIL=support@your-domain.com
# MAIL_APP_URL=https://play.google.com/store/apps/details?id=com.freemocktest.app
# MAIL_COMPLETE_PROFILE_DEEP_LINK=mocktestapp://complete-profile
# PASSWORD_RESET_OTP_MINUTES=15

# OTP send rate limits (single API instance; in-memory). Reduces Gmail 454 / abuse.
# OTP_REQUEST_WINDOW_MS=900000
# OTP_PASSWORD_RESET_MAX_PER_IP=30
# OTP_PASSWORD_RESET_MAX_PER_EMAIL=5
# OTP_EMAIL_VERIFY_MAX_PER_USER=8
# Reuse one SMTP pool for OTP mail (fewer AUTH handshakes to Gmail)
# SMTP_POOL_MAX_MESSAGES=200

# FCM Push (admin-controlled notifications)
FCM_PROJECT_ID=your-firebase-project-id
# Keep as single-line JSON string of service account
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-firebase-project-id"}

# Attempts submit protection (Phase-3/4)
# Per-user limit in one window.
# ATTEMPT_SUBMIT_WINDOW_MS=10000
# ATTEMPT_SUBMIT_MAX_PER_WINDOW=8
# Global submit cap in one window across users.
# ATTEMPT_SUBMIT_GLOBAL_MAX_PER_WINDOW=500
