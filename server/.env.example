PORT=3000
DATABASE_URL=postgresql://mocktestapp_rw:MockDb123@127.0.0.1:5432/mocktestapp
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Google Sign-In (same Web client ID as Android local.properties mocktest.googleWebClientId)
GOOGLE_WEB_CLIENT_ID=your-client-id.apps.googleusercontent.com
ACCESS_TOKEN_TTL_SECONDS=86400
REFRESH_TOKEN_TTL_DAYS=14

# Password reset (Gmail): enable 2-Step Verification, then create an App Password
# https://myaccount.google.com/apppasswords — use that value for SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youraccount@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM="MockTestApp <youraccount@gmail.com>"
# SMTP timeout tuning (prevents long hangs on hosted environments)
# SMTP_CONNECTION_TIMEOUT_MS=10000
# SMTP_GREETING_TIMEOUT_MS=10000
# SMTP_SOCKET_TIMEOUT_MS=15000
# Optional:
# MAIL_SUBJECT_RESET=Your reset code
# MAIL_SUBJECT_EMAIL_VERIFY=Your verification code
# MAIL_BRAND_NAME=MockTestApp
# MAIL_LOGO_URL=https://your-domain.com/logo.png
# MAIL_SUPPORT_EMAIL=support@your-domain.com
# MAIL_APP_URL=https://play.google.com/store/apps/details?id=com.freemocktest.app
# MAIL_COMPLETE_PROFILE_DEEP_LINK=mocktestapp://complete-profile
# PASSWORD_RESET_OTP_MINUTES=15

# FCM Push (admin-controlled notifications)
FCM_PROJECT_ID=your-firebase-project-id
# Keep as single-line JSON string of service account
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-firebase-project-id"}
