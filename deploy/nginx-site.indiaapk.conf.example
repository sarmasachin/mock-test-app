# DEPRECATED — do not use. Use nginx-site.govmocktest.conf.example + deploy/DEPLOY.txt
# Old domain indiaapk.com — production is admin-admin.govmocktest.com only.
# Copy to VPS: /etc/nginx/sites-available/indiaapk.com
# sudo cp nginx-site.indiaapk.conf.example /etc/nginx/sites-available/indiaapk.com
# Adjust root paths and ssl cert names if needed.
# sudo nginx -t && sudo systemctl reload nginx
#
# Admin static: deploy-admin.ps1 uploads admin-web/dist → /var/www/indiaapk-admin/dist/
# API: Node (e.g. PM2) must listen on 127.0.0.1:3000 — admin-web calls https://YOUR_DOMAIN/v1/...

upstream mocktest_api {
    server 127.0.0.1:3000;
    keepalive 16;
}

# HTTP — ACME + correct HTTPS redirect (do NOT use "return 301 https://;" alone)
server {
    listen 80;
    listen [::]:80;
    server_name indiaapk.com www.indiaapk.com;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
        default_type "text/plain";
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS — single SPA root under /admin/ (avoid duplicate "location /admin/" blocks)
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name indiaapk.com www.indiaapk.com;

    ssl_certificate     /etc/letsencrypt/live/indiaapk.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/indiaapk.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
        default_type "text/plain";
    }

    location = /health {
        proxy_pass http://mocktest_api/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /v1/ {
        proxy_pass http://mocktest_api/v1/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    location /uploads/ {
        proxy_pass http://mocktest_api/uploads/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /admin {
        return 301 /admin/;
    }

    location /admin/ {
        alias /var/www/indiaapk-admin/dist/;
        index index.html;
        try_files $uri $uri/ /admin/index.html;
    }

    location / {
        return 404;
    }
}
