# Production ONLY — admin-admin.govmocktest.com
# cp deploy/nginx-site.govmocktest.conf.example /etc/nginx/sites-available/admin-admin.govmocktest.com
# ln -sf /etc/nginx/sites-available/admin-admin.govmocktest.com /etc/nginx/sites-enabled/
# rm -f /etc/nginx/sites-enabled/livehospital* /etc/nginx/sites-enabled/indiaapk*
# nginx -t && systemctl reload nginx
# certbot --nginx -d admin-admin.govmocktest.com
#
# Admin static: /var/www/admin-admin.govmocktest.com/site/admin/  (Vite dist contents)
# API: PM2 mocktest-api on 127.0.0.1:3000

upstream mocktest_api {
    server 127.0.0.1:3000;
    keepalive 16;
}

server {
    listen 80;
    listen [::]:80;
    server_name admin-admin.govmocktest.com;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
        default_type "text/plain";
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name admin-admin.govmocktest.com;

    ssl_certificate     /etc/letsencrypt/live/admin-admin.govmocktest.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/admin-admin.govmocktest.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
        default_type "text/plain";
    }

    location = /health {
        proxy_pass http://mocktest_api/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /v1/ {
        proxy_pass http://mocktest_api/v1/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    location /uploads/ {
        proxy_pass http://mocktest_api/uploads/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = / {
        return 301 /admin/;
    }

    location = /admin {
        return 301 /admin/;
    }

    # root + try_files (avoid alias redirect cycle)
    location /admin/ {
        root /var/www/admin-admin.govmocktest.com/site;
        index index.html;
        try_files $uri $uri/ /admin/index.html;
    }

    location / {
        return 404;
    }
}
